# ─────────────────────────────────────────────────────────────
# Konfiguracja integracji leadów (skopiuj do pliku .env i uzupełnij)
# ─────────────────────────────────────────────────────────────

# Klucz dostępu Web3Forms — leady lecą wtedy PROSTO NA E-MAIL.
# Pobierz darmowy klucz na https://web3forms.com (wpisz swój adres e-mail).
# To najprostszy start, gdy leadów jest jeszcze mało. Klucz jest bezpieczny
# do umieszczenia po stronie klienta (nie ujawnia Twojego adresu e-mail).
VITE_WEB3FORMS_KEY=

# Adres webhooka (n8n / Make.com / własny endpoint) — docelowy tryb produkcyjny.
# Gdy ustawiony, MA PIERWSZEŃSTWO nad e-mailem. Dalej rozsyła dane do
# Airtable, Google Sheets, CRM, SMS itd. (patrz README -> Integracje).
# Gdy oba puste — dane trafiają tylko do localStorage (tryb deweloperski).
VITE_LEAD_WEBHOOK_URL=

# Opcjonalnie: numer WhatsApp w formacie międzynarodowym bez znaków (np. 48512491787)
VITE_WHATSAPP=48512491787

# ─────────────────────────────────────────────────────────────
# Analityka i reklamy (ładowane DOPIERO po zgodzie na cookies)
# Zalecane: wpnij sam GTM, a Pixel/Ads skonfiguruj w panelu GTM
# na zdarzeniach z dataLayer (lead_submit, calculator_complete, cta_click).
# ─────────────────────────────────────────────────────────────

# Google Tag Manager — ID kontenera
VITE_GTM_ID=

# Meta (Facebook) Pixel — ID piksela
VITE_META_PIXEL_ID=

# Google Ads — ID konta (np. AW-XXXXXXXXX) i etykieta konwersji leada
VITE_GADS_ID=
VITE_GADS_CONVERSION_LABEL=
