# ─────────────────────────────────────────────────────────────
# Konfiguracja integracji leadów (skopiuj do pliku .env i uzupełnij)
# ─────────────────────────────────────────────────────────────

# Adres webhooka, na który wysyłane są zgłoszenia z kalkulatora i formularzy.
# Najwygodniej wskazać tu webhook n8n / Make.com, który dalej rozsyła dane
# do Airtable, Google Sheets, CRM, SMS itd. (patrz README -> Integracje).
# Gdy puste — dane trafiają tylko do localStorage (tryb deweloperski).
VITE_LEAD_WEBHOOK_URL=

# Opcjonalnie: numer WhatsApp w formacie międzynarodowym bez znaków (np. 48512491787)
VITE_WHATSAPP=48512491787
